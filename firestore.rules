rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'wardopon123@gmail.com';
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // Products — signed-in users can read; only stock/updatedAt writable by non-admins
    match /products/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt']));
    }

    // Transactions — any signed-in user can read/create (staff need all for reports)
    match /transactions/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Prescriptions — signed-in can read/create/update, admin can delete
    match /prescriptions/{id} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Customers — signed-in can read/create, admin full access
    match /customers/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Staff — admin full access, any signed-in user can read (needed for getUserRole query)
    match /staff/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Activity log — signed-in can create, admin reads all
    match /activityLog/{id} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
    }

    // Returns — any signed-in user can read/create, admin can update/delete
    match /returns/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Stock Movements — signed-in can read/create, admin can update/delete
    match /stockMovements/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Deleted Products — admin full access
    match /deletedProducts/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
