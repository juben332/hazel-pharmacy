rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'wardopon123@gmail.com';
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // Products — signed-in users can read and update stock, only admin can add/delete
    match /products/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn();
      allow create, delete: if isAdmin();
    }

    // Transactions — cashier can create, admin reads all, cashier reads own
    match /transactions/{id} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn() && (
        isAdmin() || resource.data.cashierId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    // Prescriptions — signed-in can create/read, admin full access
    match /prescriptions/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Customers — signed-in can read/create, admin full access
    match /customers/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Staff — admin full access, signed-in users can read their own record
    match /staff/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
    }

    // Activity log — signed-in can create, admin reads all
    match /activityLog/{id} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
    }
  }
}
